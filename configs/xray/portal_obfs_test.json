{
    "log": {
        "loglevel": "debug"
    },
    "inbounds": [
        // 1. User Mixed SOCKS5/HTTP inbound to receive traffic locally
        {
            "tag": "socks-in",
            "port": 10800,
            "listen": "127.0.0.1",
            "protocol": "mixed",
            "settings": {
                "auth": "noauth",
                "udp": true
            }
        },
        // 2. High-performance, Direct-to-CDN VLESS Reverse Portal Inbound
        // Terminates TLS natively on port 443 with self-signed certificate paths
        {
            "tag": "IN_100-10-01-05",
            "listen": "0.0.0.0",
            "port": 443,
            "protocol": "vless",
            "settings": {
                "clients": [
                    {
                        "id": "58764c09-99c3-4496-9591-9cff83e4c7b7",
                        "email": "de08-cf@reverse",
                        "reverse": {
                            "tag": "reverse-out-08-cf"
                        }
                    }
                ],
                "decryption": "none"
            },
            "streamSettings": {
                "network": "xhttp",
                "security": "tls",
                "tlsSettings": {
                    "certificates": [
                        {
                            "certificateFile": "/opt/node/certs/ssl_bundle.pem",
                            "keyFile": "/opt/node/certs/ssl_bundle.pem"
                        }
                    ],
                    "alpn": ["h2"]
                },
                "xhttpSettings": {
                    "path": "/21-08-07-06",
                    "mode": "auto",
                    "extra": {
                        // Matching obfuscation and padding parameters on the server side
                        "xPaddingBytes": "500-1500",
                        "xPaddingObfsMode": true
                    }
                }
            }
        }
    ],
    "outbounds": [
        {
            "protocol": "freedom",
            "tag": "direct"
        },
        {
            "protocol": "blackhole",
            "tag": "block"
        }
    ],
    "routing": {
        "domainStrategy": "AsIs",
        "rules": [
            // Route local socks traffic into the pre-established reverse channel
            {
                "type": "field",
                "inboundTag": ["socks-in"],
                "outboundTag": "reverse-out-08-cf"
            },
            {
                "type": "field",
                "port": "0-65535",
                "outboundTag": "block"
            }
        ]
    }
}
