{
    "log": {
        "loglevel": "debug"
    },
    "dns": {
        "hosts": {
            "new-state.ir": "185.204.197.242",
            "i-05.new-state.ir": "62.220.123.35"
        },
        "servers": [
            {
                "tag": "dns-out",
                "address": "https+local://i-05.new-state.ir/dns-query"
            },
            {
                "tag": "dns-out",
                "address": "10.255.1.5",
                "port": 53
            }
        ]
    },
    "inbounds": [
        // 1. User Egress SOCKS5/Mixed Inbound (used to receive users' traffic inside Iran)
        {
            "tag": "socks-in",
            "port": 10800,
            "listen": "0.0.0.0",
            "protocol": "mixed",
            "settings": {
                "auth": "noauth",
                "udp": true
            }
        },
        // 2. High-performance, Direct-to-CDN VLESS Reverse Portal Inbound
        // Terminates TLS directly inside Xray on port 443 using Marzban node self-signed certs
        {
            "tag": "IN_100-10-01-05",
            "listen": "0.0.0.0",
            "port": 443,
            "protocol": "vless",
            "settings": {
                "clients": [
                    {
                        "id": "58764c09-99c3-4496-9591-9cff83e4c7b7",
                        "email": "de08@reverse",
                        "reverse": {
                            "tag": "reverse-out-001"
                        }
                    }
                ],
                "decryption": "none"
            },
            "streamSettings": {
                "network": "xhttp",
                "security": "tls",
                "tlsSettings": {
                    "certificates": [
                        {
                            "certificateFile": "/var/lib/marzban-node/ssl_cert.pem",
                            "keyFile": "/var/lib/marzban-node/ssl_key.pem"
                        }
                    ],
                    "alpn": ["h2"]
                },
                "xhttpSettings": {
                    "path": "/",
                    "mode": "auto"
                }
            }
        }
    ],
    "outbounds": [
        // 1. Direct egress (used as fallback or for local queries)
        {
            "protocol": "freedom",
            "tag": "direct"
        },
        // 2. Block/Blackhole outbound for security
        {
            "protocol": "blackhole",
            "tag": "block"
        }
    ],
    "observatory": {
        "subjectSelector": [
            "reverse-out-"
        ],
        "probeUrl": "https://www.google.com/generate_204",
        "probeInterval": "10s"
    },
    "routing": {
        "domainStrategy": "AsIs",
        "balancers": [
            {
                "tag": "balancer_100",
                "selector": [
                    "reverse-out-"
                ],
                "strategy": {
                    "type": "leastPing"
                },
                "fallbackTag": "direct"
            }
        ],
        "rules": [
            // Route all incoming user mixed/socks traffic to the reverse balancer
            {
                "type": "field",
                "inboundTag": [
                    "socks-in"
                ],
                "balancerTag": "balancer_100"
            },
            // Fallback: block all other traffic to ensure secure operation
            {
                "type": "field",
                "port": "0-65535",
                "outboundTag": "block"
            }
        ]
    }
}
